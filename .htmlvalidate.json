{
  "extends": ["html-validate:recommended"],
  "rules": {
    "heading-level": "off",
    "no-inline-style": "off",
    "svg-focusable": "off",
    "prefer-native-element": "off",
    "long-title": "off",
    "void-style": "off",
    "doctype-style": "off",
    "no-trailing-whitespace": "off",
    "prefer-tbody": "off"
  }
}
